{
    "compilerOptions": {
        "baseUrl": ".",
        "paths": {
            "@/*": ["resources/js/*"]
        },
        "target": "ES6",
        "module": "commonjs",
        "allowSyntheticDefaultImports": true
    },
    "include": [
        "resources/js/**/*",
        "resources/js/**/*.vue"
    ],
    "exclude": ["node_modules", "public"]
}