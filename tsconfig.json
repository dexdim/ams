{
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,           // <--- THIS IS THE KEY: Tells TS not to create any files
    "outDir": "./dist",       // <--- Keeps the "output" separate from the "input"
    "baseUrl": ".",
    "paths": {
      "@/*": ["resources/js/*"]
    },
    // ... rest of your settings
  },
  "include": [
    "resources/js/**/*"
  ],
  "exclude": ["node_modules", "public", "vendor", "dist"]
}